menu "Network Configuration"    
    menu "WiFi Configuration"
        config ESP_WIFI_SSID
            string "WiFi SSID"
            default "YOUR_WIFI_SSID"

        config ESP_WIFI_PASSWORD
            string "WiFi Password"
            default "YOUR_WIFI_PASSWORD"
    endmenu

    menu "Local Network Configuration"
        config UDP_TARGET_IP
            string "UDP Broadcast Target IP"
            default "YOUR_TARGET_IP"
            help
                - "255.255.255.255": Global Broadcast (Blocked by some Mobile Hotspots).
                - "192.168.x.255": Subnet Broadcast (Recommended for Hotspots).
                - "192.168.x.x": Unicast to specific PC (Best stability but static IP needed).
    endmenu

    menu "Huawei Cloud IoT Configuration"

    config HWC_MQTT_BROKER_URL
        string "MQTT Broker URL"
        default "YOUR_PROJECT_ID.YOUR_AREA.com:8883"
        help
            Use mqtt:// for port 1883 (No SSL). Use mqtts:// for 8883 (SSL required).
            For project development, mqtt:// (1883) is recommended.

    config HWC_DEVICE_ID
        string "Device ID"
        default "YOUR_DEVICE_ID"
        help
            This is also the MQTT Username.

    config HWC_CLIENT_ID
        string "MQTT Client ID"
        default "YOUR_CLIENT_ID"
        help
            Generated by Huawei Cloud tool.

    config HWC_MQTT_PASSWORD
        string "MQTT Password"
        default "YOUR_MQTT_PASSWORD"
        help
            HMAC-SHA256 generated password.
    endmenu

endmenu